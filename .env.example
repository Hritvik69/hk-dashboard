# Optional: enable cross-device login and cloud saving through Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# These names also work if Supabase/Vercel gives them to you:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional but recommended for Supabase magic links.
# Set this to your live Vercel dashboard URL so email links never fall back to localhost.
NEXT_PUBLIC_SITE_URL=
VITE_SITE_URL=

# Optional but recommended: protect shared dashboard state/files API.
# Use the same value as the dashboard password.
DASHBOARD_ACCESS_KEY=

# Optional: JSON endpoint for Tomorrow's Picks from your stock scanner.
# It should return either an array of picks, or an object with a "picks" array.
VITE_STOCK_PICKS_URL=
NEXT_PUBLIC_STOCK_PICKS_URL=

# Local-only sync from your private Odysseus into this Supabase project.
# Do not add SUPABASE_SERVICE_ROLE_KEY to Vercel frontend env vars.
ODYSSEUS_URL=http://127.0.0.1:7000
ODYSSEUS_API_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USER_EMAIL=

# HK AI assistant (Vercel server-side only — never expose in frontend env).
# Set one or more keys; auto mode tries them in AI_PROVIDER_ORDER.
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# auto | gemini | openrouter | groq | openai
AI_PROVIDER=auto
AI_PROVIDER_ORDER=gemini,openrouter,groq,openai

# Optional model overrides:
# GEMINI_MODEL=gemini-1.5-flash
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# GROQ_MODEL=llama-3.1-8b-instant
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
